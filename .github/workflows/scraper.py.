import os
import re
import json
import requests
import time

def extract_teams(raw_text):
    teams_list = []
    lines = raw_text.strip().split('\n')
    
    for line in lines:
        if " - " in line or " vs " in line:
            # Remove times like 15:30
            clean_line = re.sub(r'\d{2}:\d{2}', '', line).strip()
            
            # Split by common separators
            if " - " in clean_line:
                parts = clean_line.split(" - ")
            else:
                parts = clean_line.split(" vs ")
                
            if len(parts) >= 2:
                home_team = parts[0].strip()
                # Clean away odds or brackets from the away team
                away_team = parts[1].split('(')[0].strip()
                teams_list.extend([home_team, away_team])
                
    return list(set(teams_list)) # Remove duplicates

